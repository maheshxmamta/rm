Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", "Define", " ", "the", " ", "interval", " ", "and", " ", "the", " ",
     "number", " ", "of", " ", "sample", " ", "points", " ", 
    RowBox[{"(", "N", ")"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"a", "=", "0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"b", "=", 
     RowBox[{"2", "*", "Pi"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Npoints", "=", "50"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Calculate", " ", "the", " ", "step", " ", "size", " ", "epsilon"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"epsilon", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"b", "-", "a"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"Npoints", "-", "1"}], ")"}]}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Create", " ", "the", " ", "time", " ", "vector", " ", "by", " ",
      "sampling", " ", "the", " ", "interval"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tValues", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"t", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "a", ",", "b", ",", "epsilon"}], "}"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Evaluate", " ", "the", " ", "continuous", " ", "function", " ",
      "to", " ", "create", " ", "the", " ", "signal", " ", "vector"}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gVector", "=", 
     RowBox[{"Sin", "[", "tValues", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Visualize", " ", "the", " ", "discrete", " ", "vector", " ", 
     "data"}], "*)"}], "\[IndentingNewLine]", 
