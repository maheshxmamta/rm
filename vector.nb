Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Continuous", " ", 
    RowBox[{"approach", ":", 
     RowBox[{
     "Evaluate", " ", "the", " ", "inner", " ", "product", " ", 
      "integral"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{"continuousInnerProduct", "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", "t", "]"}], "*", 
       RowBox[{"Cos", "[", "t", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", 
        RowBox[{"2", "*", "Pi"}]}], "}"}]}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Continuous Inner Product: \>\"", ",", 
      "continuousInnerProduct"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Discrete", " ", 
     RowBox[{"approach", ":", 
      RowBox[{
      "Create", " ", "a", " ", "second", " ", "vector", " ", "for", " ", 
       "Cos", 
       RowBox[{"(", "t", ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xVector", "=", 
     RowBox[{"Cos", "[", "tValues", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Calculate", " ", "the", " ", "dot", " ", "product", " ", "of", " ", 
     "the", " ", "two", " ", "vectors"}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Note", ":", 
     RowBox[{
     "We", " ", "multiply", " ", "by", " ", "epsilon", " ", "to", " ", 
      "approximate", " ", "the", " ", "integral", " ", "area"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"discreteInnerProduct", "=", 
     RowBox[{
      RowBox[{"Dot", "[", 
       RowBox[{"gVector", ",", "xVector"}], "]"}], "*", "epsilon"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Discrete Inner Product (approx): \>\"", ",", 
      "discreteInnerProduct"}], "]"}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "The", " ", "discrete", " ", "inner", " ", "product", " ", "should", " ", 
     "be", " ", "extremely", " ", "close", " ", "to", " ", "0"}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9823683918688297`*^9, 3.9823683918688297`*^9}},
