Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", "Define", " ", "the", " ", "square", " ", "wave", " ", "signal",
     " ", "and", " ", "the", " ", "basis", " ", "signal", " ", 
    RowBox[{"over", "[", 
     RowBox[{"0", ",", 
      RowBox[{"2", "Pi"}]}], "]"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"gSignal", "[", "t_", "]"}], ":=", 
     RowBox[{"Sign", "[", 
      RowBox[{"Sin", "[", "t", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"xSignal", "[", "t_", "]"}], ":=", 
     RowBox[{"Cos", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Calculate", " ", "the", " ", "energy", " ", "of", " ", "the", 
     " ", "basis", " ", "signal", " ", "Ex"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ex", "=", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"xSignal", "[", "t", "]"}], "^", "2"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", 
         RowBox[{"2", "*", "Pi"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Calculate", " ", "the", " ", "optimum", " ", "projection", " ",
      "coefficient", " ", "c"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"c", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "Ex"}], ")"}], "*", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"gSignal", "[", "t", "]"}], "*", 
         RowBox[{"xSignal", "[", "t", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", 
          RowBox[{"2", "*", "Pi"}]}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Optimum coefficient c = \>\"", ",", "c"}], "]"}], ";"}], 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"The", " ", "output", " ", "should", " ", "yield", " ", 
      RowBox[{"4", "/", "Pi"}]}], ",", 
     RowBox[{"matching", " ", "the", " ", 
      RowBox[{"text", "'"}], "s", " ", "derivation"}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Plot", " ", "the", " ", "original", " ", "square", " ", 
     "wave", " ", "and", " ", "its", " ", "sinusoidal", " ", "component"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"gSignal", "[", "t", "]"}], ",", 
       RowBox[{"c", "*", 
