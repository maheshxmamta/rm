Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{"s", ",", "GH", ",", "k"}], "]"}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Define", " ", "the", " ", "Open"}], "-", 
    RowBox[{"Loop", " ", "Transfer", " ", "Function"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"GH", "=", 
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{"s", "*", 
       RowBox[{"(", 
        RowBox[{"s", "+", "2"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"s", "+", "4"}], ")"}]}], ")"}]}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Simplify", " ", "the", " ", "transfer", " ", "function", " ", "and", " ", 
    "extract", " ", "numerator", " ", "and", " ", "denominator"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"num", "=", 
   RowBox[{"Numerator", "[", 
    RowBox[{"Cancel", "[", "GH", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"den", "=", 
    RowBox[{"Denominator", "[", 
     RowBox[{"Cancel", "[", "GH", "]"}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Safe", " ", "Extraction", " ", "of", " ", "Poles", " ", 
    RowBox[{"(", 
     RowBox[{"K", "=", "0"}], ")"}], " ", "and", " ", "Zeros", " ", 
    RowBox[{"(", 
     RowBox[{"K", "=", "\[Infinity]"}], ")"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pSol", "=", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"den", "==", "0"}], ",", "s"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"poles", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "pSol", "]"}], "==", "0"}], ",", 
      RowBox[{"{", "}"}], ",", 
      RowBox[{"s", "/.", " ", "pSol"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"zSol", "=", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"num", "==", "0"}], ",", "s"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"zeros", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "zSol", "]"}], "==", "0"}], ",", 
      RowBox[{"{", "}"}], ",", 
      RowBox[{"s", "/.", " ", "zSol"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"n", "=", 
   RowBox[{"Length", "[", "poles", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"m", "=", 
    RowBox[{"Length", "[", "zeros", "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Rule", " ", "5"}], ":", 
    RowBox[{"Calculate", " ", "Centroid", " ", 
     RowBox[{"(", "\[Sigma]", ")"}], " ", "of", " ", "Asymptotes"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"centroid", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"n", ">", "m"}], ",", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Total", "[", "poles", "]"}], "-", 
          RowBox[{"Total", "[", "zeros", "]"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"n", "-", "m"}], ")"}]}], "]"}], 
      ",", "\"\<N/A (n <= m)\>\""}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Asymptote", " ", "Angles", " ", 
    RowBox[{"(", "\[Theta]_q", ")"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"angles", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"n", ">", "m"}], ",", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", " ", "q"}], "+", "1"}], ")"}], " ", 
          RowBox[{"Pi", "/", 
           RowBox[{"(", 
            RowBox[{"n", "-", "m"}], ")"}]}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "0", ",", 
          RowBox[{"n", "-", "m", "-", "1"}]}], "}"}]}], "]"}], 
      ",", "\"\<N/A\>\""}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Rule", " ", "8"}], ":", 
    RowBox[{
     RowBox[{"Safe", " ", "Extraction", " ", "of", " ", 
      RowBox[{"Breakaway", "/", "Break"}]}], "-", 
     RowBox[{"in", " ", "Points"}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bSol", "=", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"GH", ",", "s"}], "]"}], "==", "0"}], ",", "s"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"breakawayPts", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "bSol", "]"}], "==", "0"}], ",", 
      RowBox[{"{", "}"}], ",", 
      RowBox[{"s", "/.", " ", "bSol"}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Print", " ", "the", " ", "calculated", " ", "parameters", " ", 
    "cleanly"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<Root Locus Parameters\>\"", ",", "Bold", ",", "14"}], "]"}], 
   "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<1. Open-Loop Poles (n=\>\"", ",", "n", ",", "\"\<): \>\"", ",",
     "poles"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<2. Open-Loop Zeros (m=\>\"", ",", "m", ",", "\"\<): \>\"", ",",
     "zeros"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<3. Number of Asymptotes (n-m): \>\"", ",", 
    RowBox[{"n", "-", "m"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<4. Asymptote Centroid (\[Sigma]): \>\"", ",", "centroid"}], 
   "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<5. Asymptote Angles (\[Theta]): \>\"", ",", "angles", 
    ",", "\"\< (in Radians)\>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<6. Breakaway/Break-in Points: \>\"", ",", 
     RowBox[{"N", "[", "breakawayPts", "]"}]}], "]"}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Built", "-", 
    RowBox[{"in", " ", 
     RowBox[{"visualization", ":", 
      RowBox[{
      "Convert", " ", "to", " ", "TransferFunctionModel", " ", "for", " ", 
       "accurate", " ", "plotting"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Explicitly", " ", "include", " ", "the", " ", "gain", " ", 
    RowBox[{"parameter", "'"}], 
    RowBox[{"k", "'"}], " ", "inside", " ", "the", " ", "system"}], "*)"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"RootLocusPlot", "[", 
  RowBox[{
   RowBox[{"k", "*", "GH"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "0", ",", "100"}], "}"}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<Root Locus Plot\>\""}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"GridLines", "->", "Automatic"}]}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.987054386870556*^9, 3.987054412117319*^9}, {
