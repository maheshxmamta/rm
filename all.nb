   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"nextRow", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Simplify", "[", 
