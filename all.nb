            ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"nextRow", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"nextRow", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "=", "\[Epsilon]"}]}], "]"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
