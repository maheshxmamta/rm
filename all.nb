Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"1.", " ", "THE", " ", "TIME", " ", "VECTOR", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"For", " ", "Legendre"}], ",", " ", 
      RowBox[{
       RowBox[{"we", " ", "usually", " ", "evaluate", " ", "from"}], " ", "-", 
       RowBox[{"1", " ", "to", " ", "1"}]}]}], ")"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Npts", " ", "=", " ", "100"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"t", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{"k", ",", " ", 
      RowBox[{"{", 
       RowBox[{"k", ",", " ", 
        RowBox[{"-", "1.0"}], ",", " ", "1.0", ",", " ", 
        RowBox[{"2.0", "/", 
         RowBox[{"(", 
          RowBox[{"Npts", " ", "-", " ", "1"}], ")"}]}]}], "}"}]}], "]"}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"2.", " ", "THE", " ", "SIGNAL"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"signal", " ", "=", " ", 
    RowBox[{
     RowBox[{"8", "*", 
      RowBox[{"(", "t", ")"}]}], " ", "+", " ", 
     RowBox[{"3", "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"1.5", "*", 
         RowBox[{"t", "^", "2"}]}], " ", "-", " ", "0.5"}], ")"}]}]}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"3.", " ", "THE", " ", "BASIS", " ", "VECTORS", " ", 
    RowBox[{"(", 
     RowBox[{"Stripped", " ", "from", " ", "the", " ", "signal"}], ")"}]}], 
   " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"b1", " ", "=", " ", "t"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"b2", " ", "=", " ", 
    RowBox[{
     RowBox[{"1.5", "*", 
      RowBox[{"t", "^", "2"}]}], " ", "-", " ", "0.5"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"4.", " ", "ORTHOGONALITY", " ", "CHECK"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", "\"\<--- ORTHOGONALITY ---\>\"", "]"}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "We", " ", "use", " ", "Chop", " ", "to", " ", "ignore", " ", 
    "microscopic", " ", "rounding", " ", "errors"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<b1 . b2 = \>\"", ",", " ", 
     RowBox[{"Chop", "[", 
      RowBox[{"b1", " ", ".", " ", "b2"}], "]"}]}], "]"}], ";"}], " ", "\n", 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"5.", " ", "CALCULATE", " ", "PROJECTIONS", " ", 
    RowBox[{"(", 
     RowBox[{
     "This", " ", "only", " ", "works", " ", "because", " ", "the", " ", 
      "step", " ", "above", " ", "was", " ", 
      RowBox[{"0", "!"}]}], ")"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"c1", " ", "=", " ", 
   RowBox[{"Chop", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"signal", " ", ".", " ", "b1"}], ")"}], " ", "/", " ", 
     RowBox[{"(", 
      RowBox[{"b1", " ", ".", " ", "b1"}], ")"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"c2", " ", "=", " ", 
    RowBox[{"Chop", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"signal", " ", ".", " ", "b2"}], ")"}], " ", "/", " ", 
      RowBox[{"(", 
       RowBox[{"b2", " ", ".", " ", "b2"}], ")"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<\\n--- COEFFICIENTS ---\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Amount of b1 (Expected 8): \>\"", ",", " ", "c1"}], "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Amount of b2 (Expected 3): \>\"", ",", " ", "c2"}], "]"}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"6.", " ", "VISUAL", " ", "PROOF"}], " ", "*)"}]}], "\n", 
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"signal", ",", " ", 
     RowBox[{"c1", "*", "b1"}], ",", " ", 
     RowBox[{"c2", "*", "b2"}]}], "}"}], ",", " ", "\n", "  ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Composite Signal\>\"", ",", " ", "\"\<b1 Component\>\"", ",",
       " ", "\"\<b2 Component\>\""}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.987123092081152*^9, 3.9871230920821514`*^9}},
