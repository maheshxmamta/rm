       RowBox[{"table", ",", 
        RowBox[{"Join", "[", 
         RowBox[{"nextRow", ",", 
          RowBox[{"{", "0", "}"}]}], "]"}]}], "]"}]}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"i", ",", "3", ",", 
      RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
