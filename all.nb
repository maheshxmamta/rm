        RowBox[{
         RowBox[{"Ceiling", "[", 
          RowBox[{"n", "/", "2"}], "]"}], "+", "1"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"row2", "=", 
      RowBox[{"PadRight", "[", 
       RowBox[{
        RowBox[{"Reverse", "[", 
         RowBox[{"Take", "[", 
          RowBox[{"coeffs", ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", 
             RowBox[{"-", "1"}], ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
        RowBox[{
         RowBox[{"Ceiling", "[", 
          RowBox[{"n", "/", "2"}], "]"}], "+", "1"}]}], "]"}]}]}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
